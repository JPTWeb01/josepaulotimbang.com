{
  "name": "josepaulotimbang/portfolio-api",
  "description": "Portfolio REST API — CodeIgniter 4",
  "type": "project",
  "require": {
    "php": "^8.1",
    "codeigniter4/framework": "^4.5",
    "firebase/php-jwt": "^6.10"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "exclude-from-classmap": [
      "**/Database/Migrations/**"
    ]
  },
  "scripts": {
    "post-update-cmd": [
      "@php spark optimize"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
